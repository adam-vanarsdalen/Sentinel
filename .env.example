# Copy to .env and edit for local development.
#
# SECURITY NOTE:
# - Do not commit real secrets.
# - In production, use secret managers / injected env vars.

# --- Postgres ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev_password_change_me
POSTGRES_DB=sentinel

# Used by backend container
DATABASE_URL=postgresql+psycopg://sentinel:sentinel_dev_password_change_me@postgres:5432/sentinel

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Runtime Ports ---
# Host ports (override if you already use 8000/3000).
BACKEND_PORT=8000
FRONTEND_PORT=3000
APP_VERSION=0.1.0

JWT_SECRET=dev_jwt_secret_change_me
# Optional for local dev. If unset, Sentinel derives a development-only key from JWT_SECRET.
SENTINEL_SECRET_KEY=
JWT_ISSUER=sentinel
JWT_AUDIENCE=sentinel-ui
ACCESS_TOKEN_EXPIRES_MINUTES=480

CORS_ORIGINS=http://localhost:3000
SENTINEL_PRESET=general

# Seed demo data on startup (backend container only).
# For production deployments, set SEED_DEMO=0.
SEED_DEMO=1
DEMO_SUPER_ADMIN_EMAIL=platform-admin@example.com
DEMO_SUPER_ADMIN_PASSWORD=ChangeMe!12345
DEMO_TENANT_ADMIN_EMAIL=admin@demoorg.com
DEMO_TENANT_ADMIN_PASSWORD=ChangeMe!12345
# If you change demo passwords after first run, set this to 1 to sync the DB user hashes on startup.
DEMO_PASSWORD_SYNC=0
# Deterministic demo gateway API key token (hashed at rest in DB).
# Seeded primary demo API key name: `northwind-ops-assistant`
# Legal compatibility key also exists: `demo-contract-review`
# Format must be: sk_<8chars>_<secret>
DEMO_APP_API_KEY=sk_deadbeef_demo_secret_change_me

# LLM Providers
# Development fallback only.
# Preferred approach: configure provider credentials per organization in the UI.
PROVIDER_DEFAULT=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_ENABLED=0
OLLAMA_BASE_URL=http://localhost:11434/v1/
OLLAMA_API_KEY=
OLLAMA_DEFAULT_MODEL=gpt-oss:120b-cloud

# Rate limiting (fixed-window, per minute)
RATE_LIMIT_TENANT_PER_MINUTE=600
RATE_LIMIT_APIKEY_PER_MINUTE=120

# Logging policy defaults (tenant can override via policy/settings)
STORE_REDACTED_SNIPPETS_DEFAULT=0
STORE_RAW_CONTENT_DEFAULT=0

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SENTINEL_PRESET=general
# Server-side (Next.js route handlers) base URL for calling backend.
# In Docker Compose, prefer http://backend:8000
API_BASE_URL=http://backend:8000
