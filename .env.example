# Copy to .env and fill in values
# Cloud providers (leave blank to fall back to Ollama)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Ollama (local fallback — used automatically when no cloud keys are set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3.5:4b-q4_K_M

# Database (overridden by docker-compose in container)
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel

# Redis (overridden by docker-compose in container)
REDIS_URL=redis://localhost:6379/0

# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# Grounding thresholds
GROUNDING_BLOCK_THRESHOLD=0.5
GROUNDING_WARN_THRESHOLD=0.8

# Anomaly detection
ANOMALY_BASELINE_DAYS=7
ANOMALY_LOG_SIGMA=2.5
ANOMALY_THROTTLE_SIGMA=3.5
ANOMALY_PAUSE_SIGMA=5.0
ANOMALY_TERMINATE_SIGMA=7.0
