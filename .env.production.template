# Sentinel production environment template
# - No real values included.
# - Variables marked [REQUIRED] must be set for a real deployment.

# --- Postgres (container) ---
# [REQUIRED] Postgres username (used by the `postgres` container).
POSTGRES_USER=
# [REQUIRED] Postgres password (used by the `postgres` container).
POSTGRES_PASSWORD=
# [REQUIRED] Postgres database name (used by the `postgres` container).
POSTGRES_DB=

# --- Backend connectivity ---
# [REQUIRED] SQLAlchemy database URL used by backend/worker (must point at the `postgres` service in Compose).
DATABASE_URL=
# [REQUIRED] Redis connection URL used by backend/worker (must point at the `redis` service in Compose).
REDIS_URL=

# --- App metadata ---
# [REQUIRED] Set to "production" for real deployments (disables Swagger/ReDoc by default and enforces secure settings).
ENVIRONMENT=
# [OPTIONAL] Application version string returned by /healthz (defaults to "0.1.0").
APP_VERSION=

# --- JWT / Auth ---
# [REQUIRED] Secret used to sign JWT access tokens (set to a long random value).
JWT_SECRET=
# [REQUIRED] Master secret used to encrypt tenant-scoped provider credentials at rest.
SENTINEL_SECRET_KEY=
# [OPTIONAL] JWT issuer claim (defaults to "sentinel").
JWT_ISSUER=
# [OPTIONAL] JWT audience claim (defaults to "sentinel-ui").
JWT_AUDIENCE=
# [OPTIONAL] Access token TTL in minutes (defaults to 480).
ACCESS_TOKEN_EXPIRES_MINUTES=

# --- CORS ---
# [OPTIONAL] Comma-separated list of allowed origins for the backend (defaults to "http://localhost:3000").
CORS_ORIGINS=

# --- Prometheus metrics (defense-in-depth) ---
# [RECOMMENDED] Set this to a random secret in production. If not set, /metrics is publicly accessible and exposes server internals.
# Generate with: openssl rand -hex 32
METRICS_TOKEN=

# --- Provider selection ---
# [OPTIONAL] Development fallback only. In production, configure provider credentials per organization in the UI.
PROVIDER_DEFAULT=

# --- OpenAI (only required if using provider "openai") ---
# [OPTIONAL] OpenAI API key.
OPENAI_API_KEY=
# [OPTIONAL] OpenAI base URL (defaults to "https://api.openai.com/v1").
OPENAI_BASE_URL=

# --- Anthropic (only required if using provider "anthropic") ---
# [OPTIONAL] Anthropic API key.
ANTHROPIC_API_KEY=

# --- Azure OpenAI (only required if using provider "azure_openai") ---
# [OPTIONAL] Azure OpenAI endpoint, e.g. "https://<resource-name>.openai.azure.com".
AZURE_OPENAI_ENDPOINT=
# [OPTIONAL] Azure OpenAI API key.
AZURE_OPENAI_API_KEY=
# [OPTIONAL] Azure OpenAI API version string.
AZURE_OPENAI_API_VERSION=

# --- Rate limiting ---
# [OPTIONAL] Per-tenant fixed-window limit per minute (defaults to 600).
RATE_LIMIT_TENANT_PER_MINUTE=
# [OPTIONAL] Per-API-key fixed-window limit per minute (defaults to 120).
RATE_LIMIT_APIKEY_PER_MINUTE=

# --- Demo seeding (disable in production unless explicitly desired) ---
# [OPTIONAL] Set to 1/true to seed demo tenant/users on startup (defaults to false).
SEED_DEMO=
# [OPTIONAL] Demo super admin email.
DEMO_SUPER_ADMIN_EMAIL=
# [OPTIONAL] Demo super admin password.
DEMO_SUPER_ADMIN_PASSWORD=
# [OPTIONAL] Demo tenant admin email.
DEMO_TENANT_ADMIN_EMAIL=
# [OPTIONAL] Demo tenant admin password.
DEMO_TENANT_ADMIN_PASSWORD=
# [OPTIONAL] Deterministic demo gateway API key token (format: sk_<8chars>_<secret>).
DEMO_APP_API_KEY=

# --- SMTP notifications (optional) ---
# [OPTIONAL] SMTP host for high-severity audit alerts.
SMTP_HOST=
# [OPTIONAL] SMTP port (defaults to 587 if SMTP_HOST is set).
SMTP_PORT=
# [OPTIONAL] SMTP username (optional; if set, SMTP_PASSWORD should also be set).
SMTP_USER=
# [OPTIONAL] SMTP password (optional; required if SMTP_USER is set).
SMTP_PASSWORD=

# --- Logging defaults ---
# [OPTIONAL] Default: store redacted snippets in audit events (0/1; defaults to false).
STORE_REDACTED_SNIPPETS_DEFAULT=
# [OPTIONAL] Default: store raw prompt/response content in audit events (0/1; defaults to false).
STORE_RAW_CONTENT_DEFAULT=

# --- Host ports (Docker Compose) ---
# [OPTIONAL] Host port mapped to backend container port 8000 (defaults to 8000).
BACKEND_PORT=
# [OPTIONAL] Host port mapped to frontend container port 3000 (defaults to 3000).
FRONTEND_PORT=

# --- Frontend (build/runtime) ---
# [OPTIONAL] Public base URL for the browser to reach the backend API (used by the Next.js UI).
NEXT_PUBLIC_API_BASE_URL=
# [REQUIRED] Public-facing URL of the Sentinel gateway, used in the admin console integration instructions. Must include the scheme and domain, e.g. "https://console.example.com"
NEXT_PUBLIC_GATEWAY_URL=

# [OPTIONAL] Support contact email shown on /help.
SUPPORT_EMAIL=

# --- Reverse proxy / TLS (Caddy) ---
# [REQUIRED] Public domain name for HTTPS termination, e.g. "console.example.com".
PUBLIC_DOMAIN=
# [REQUIRED] Email used by Let's Encrypt for certificate issuance/renewal.
CADDY_EMAIL=
